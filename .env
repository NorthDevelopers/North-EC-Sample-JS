# North Checkout Configuration
# Local HTTPS hostnames (Caddy + setup-hosts.sh) — comma or space separated
HOST=www.test.com,test.com

# Set to 1 to enable local HTTPS (Caddy on :443 + local certs).
# Default is HTTP-only on http://127.0.0.1:8000
ENABLE_HTTPS=0

CHECKOUT_ID=
PROFILE_ID=
PRIVATE_API_KEY=

# Embedded Checkout type: form | fields | post
CHECKOUT_TYPE=form
